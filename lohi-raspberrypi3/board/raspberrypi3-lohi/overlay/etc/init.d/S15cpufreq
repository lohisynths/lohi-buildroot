#!/bin/sh

case "$1" in
	start)
		for governor in \
			/sys/devices/system/cpu/cpufreq/policy*/scaling_governor \
			/sys/devices/system/cpu/cpu*/cpufreq/scaling_governor
		do
			[ -e "${governor}" ] || continue
			printf '%s\n' performance > "${governor}" 2>/dev/null || true
		done
		;;
	stop|restart|reload)
		;;
	*)
		echo "Usage: $0 start" >&2
		exit 1
		;;
esac

exit 0
